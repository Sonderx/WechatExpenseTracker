# 开发环境配置（模板）
# 复制此文件为 application-dev.yml，填入真实值后使用
# cp application-dev.yml.example application-dev.yml

spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/expense_tracker?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: YOUR_MYSQL_USERNAME
    password: YOUR_MYSQL_PASSWORD

wx:
  mini:
    app-id: YOUR_WX_APPID
    app-secret: YOUR_WX_APPSECRET
    mock-openid: false

jwt:
  secret: YOUR_JWT_SECRET_KEY_HERE
  expiration: 604800000
