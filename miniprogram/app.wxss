/**
 * 日常记账助手 - 全局样式 v2
 * 
 * 设计系统：
 * - 主色调：#667EEA → #764BA2（渐变紫蓝，信任感）
 * - 支出色：#FF6B6B（温暖红）
 * - 收入色：#00D2D3（青色）
 * - 背景色：#F7F8FC（浅灰蓝）
 * - 卡片色：#FFFFFF
 * - 文字主色：#1A1F36（深海军蓝）
 * - 文字次色：#8792A2
 * - 分割线：#EDF0F7
 */

/* 设计系统变量（通过 class 复用） */

/* 全局样式重置 */
page {
  background-color: #F7F8FC;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #1A1F36;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx 32rpx;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

/* 金额颜色 */
.amount-expense {
  color: #FF6B6B;
}

.amount-income {
  color: #00D2D3;
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 次要按钮 */
.btn-secondary {
  background-color: #F7F8FC;
  color: #667EEA;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-secondary:active {
  background-color: #EDF0F7;
}

/* 浮动操作按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 300;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.45);
  z-index: 100;
  transition: all 0.2s ease;
}

.fab:active {
  transform: scale(0.92);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.35);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
  color: #8792A2;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-state .title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1F36;
  margin-bottom: 12rpx;
}

.empty-state .desc {
  font-size: 26rpx;
  color: #8792A2;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #EDF0F7;
  margin: 24rpx 0;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-expense {
  background-color: rgba(255, 107, 107, 0.1);
  color: #FF6B6B;
}

.tag-income {
  background-color: rgba(0, 210, 211, 0.1);
  color: #00D2D3;
}

/* 加载状态 */
.loading-tip {
  text-align: center;
  padding: 32rpx;
  color: #8792A2;
  font-size: 24rpx;
}

/* 骨架屏动画 */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}
