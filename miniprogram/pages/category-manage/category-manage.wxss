/**
 * 分类管理页样式 v2
 * 
 * 设计要点：
 * - 清爽的卡片布局
 * - 现代化的弹窗设计
 */

.page {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

/* 类型切换 */
.type-switch {
  display: flex;
  background-color: #F7F8FC;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #8792A2;
  position: relative;
  z-index: 1;
  transition: color 0.3s ease;
}

.type-item.active {
  color: #667EEA;
  font-weight: 600;
}

.type-indicator {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: calc(50% - 8rpx);
  height: calc(100% - 16rpx);
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
  transition: transform 0.3s ease;
  z-index: 0;
}

/* 分类列表 */
.category-list {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

.category-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #EDF0F7;
}

.category-item:last-child {
  border-bottom: none;
}

.category-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.category-icon {
  font-size: 36rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1F36;
  display: block;
  margin-bottom: 4rpx;
}

.category-tag {
  font-size: 20rpx;
  color: #8792A2;
  background-color: #F7F8FC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.category-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.action-btn.edit {
  color: #667EEA;
  background-color: rgba(102, 126, 234, 0.1);
}

.action-btn.delete {
  color: #FF6B6B;
  background-color: rgba(255, 107, 107, 0.1);
}

/* 新增按钮 */
.add-btn {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

.add-btn:active {
  opacity: 0.9;
}

.add-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 300;
}

.add-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(26, 31, 54, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background-color: #fff;
  border-radius: 32rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #EDF0F7;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1F36;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #F7F8FC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #8792A2;
}

.modal-form {
  padding: 32rpx 40rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #8792A2;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background-color: #F7F8FC;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1A1F36;
  box-sizing: border-box;
}

.form-placeholder {
  color: #D1D5E0;
}

.icon-select {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background-color: #F7F8FC;
  border-radius: 16rpx;
}

.icon-preview {
  font-size: 48rpx;
}

.icon-change {
  font-size: 26rpx;
  color: #8792A2;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 40rpx 32rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background-color: #F7F8FC;
  color: #8792A2;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}
