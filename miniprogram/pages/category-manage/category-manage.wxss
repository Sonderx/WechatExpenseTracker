/**
 * 分类管理页样式
 */

.page {
  padding: 20rpx 30rpx;
}

/* 类型切换 */
.type-switch {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.type-item.active {
  background-color: #fff;
  color: #1AAD19;
  font-weight: bold;
}

/* 分类列表 */
.category-list {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-item:last-child {
  border-bottom: none;
}

.category-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.category-name {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.category-tag {
  font-size: 20rpx;
  color: #999;
  background-color: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.category-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.action-btn.edit {
  color: #1AAD19;
  background-color: #e8f5e9;
}

.action-btn.delete {
  color: #EE5A5A;
  background-color: #ffebee;
}

/* 新增按钮 */
.add-btn {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #1AAD19;
  font-weight: bold;
}

.add-btn:active {
  background-color: #f5f5f5;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-form {
  margin-bottom: 30rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
}

.icon-select {
  font-size: 48rpx;
  padding: 10rpx 20rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.modal-btn.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background-color: #1AAD19;
  color: #fff;
}
