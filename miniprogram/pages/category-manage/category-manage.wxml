<!--
  分类管理页 v2
  
  设计要点：
  - 清爽的类型切换
  - 现代化分类列表
  - 优雅的弹窗设计
-->
<view class="page">
  <!-- 类型切换 -->
  <view class="type-switch">
    <view class="type-item {{type === 0 ? 'active' : ''}}" data-type="0" bindtap="switchType">
      <text class="type-text">支出分类</text>
    </view>
    <view class="type-item {{type === 1 ? 'active' : ''}}" data-type="1" bindtap="switchType">
      <text class="type-text">收入分类</text>
    </view>
    <view class="type-indicator" style="transform: translateX({{type === 0 ? '0' : '100'}}%);"></view>
  </view>

  <!-- 分类列表 -->
  <view class="category-list">
    <view class="category-item" wx:for="{{categories}}" wx:key="id">
      <view class="category-icon-wrap">
        <text class="category-icon">{{item.icon}}</text>
      </view>
      <view class="category-info">
        <text class="category-name">{{item.name}}</text>
        <text class="category-tag" wx:if="{{item.isSystem}}">系统</text>
      </view>
      <view class="category-actions" wx:if="{{!item.isSystem}}">
        <view class="action-btn edit" data-item="{{item}}" bindtap="showEditModal">
          <text>编辑</text>
        </view>
        <view class="action-btn delete" data-id="{{item.id}}" bindtap="onDelete">
          <text>删除</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 新增按钮 -->
  <view class="add-btn" bindtap="showAddModal">
    <text class="add-icon">+</text>
    <text class="add-text">新增分类</text>
  </view>

  <!-- 新增/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">{{editId ? '编辑分类' : '新增分类'}}</text>
        <view class="modal-close" bindtap="hideModal">×</view>
      </view>
      
      <view class="modal-form">
        <view class="form-group">
          <text class="form-label">名称</text>
          <input class="form-input" placeholder="输入分类名称" placeholder-class="form-placeholder" value="{{formName}}" bindinput="onNameInput" />
        </view>
        <view class="form-group">
          <text class="form-label">图标</text>
          <view class="icon-select" bindtap="selectIcon">
            <text class="icon-preview">{{formIcon}}</text>
            <text class="icon-change">点击更换</text>
          </view>
        </view>
      </view>

      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="hideModal">取消</view>
        <view class="modal-btn confirm" bindtap="onSave">确定</view>
      </view>
    </view>
  </view>
</view>
