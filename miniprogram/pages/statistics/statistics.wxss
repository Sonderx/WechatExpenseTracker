/**
 * 统计页样式 v3
 * 新增：快速跳转 + 自定义范围 + 模式切换
 */

.page {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

/* ========== 顶部模式切换 ========== */
.top-bar {
  margin-bottom: 16rpx;
}

.mode-tabs {
  display: flex;
  background-color: #EDF0F7;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #8792A2;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.mode-tab.active {
  background-color: #fff;
  color: #667EEA;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.12);
}

.picker-row {
  /* month-picker wrapper */
}

/* ========== 快速跳转 ========== */
.quick-jump-bar {
  text-align: center;
  padding: 12rpx 0;
  margin-bottom: 4rpx;
}

.quick-jump-label {
  font-size: 24rpx;
  color: #667EEA;
  font-weight: 500;
}

.quick-jump-panel {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

/* 年份选择器 */
.year-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.year-arrow {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #667EEA;
  font-weight: 300;
  background-color: #F7F8FC;
  border-radius: 50%;
}

.year-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1F36;
  margin: 0 40rpx;
  min-width: 140rpx;
  text-align: center;
}

/* 月份网格 */
.month-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.month-cell {
  padding: 20rpx 0;
  text-align: center;
  background-color: #F7F8FC;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.month-cell.current {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
}

.month-cell.current .month-cell-text {
  color: #fff;
  font-weight: 700;
}

.month-cell-text {
  font-size: 26rpx;
  color: #1A1F36;
  font-weight: 500;
}

.jump-footer {
  margin-top: 20rpx;
  text-align: center;
}

.jump-current {
  font-size: 24rpx;
  color: #8792A2;
}

/* ========== 自定义范围选择器 ========== */
.range-selector {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

/* 快捷范围按钮 */
.quick-ranges {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.quick-range-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 24rpx;
  font-weight: 500;
  color: #667EEA;
  background-color: rgba(102, 126, 234, 0.08);
  border-radius: 12rpx;
  transition: all 0.2s;
}

.quick-range-btn.active {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  font-weight: 600;
}

.quick-range-btn:active {
  opacity: 0.8;
}

.range-pickers {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.range-picker {
  flex: 1;
  text-align: center;
}

.range-label {
  display: block;
  font-size: 22rpx;
  color: #8792A2;
  margin-bottom: 8rpx;
}

.range-value {
  padding: 16rpx 8rpx;
  background-color: #F7F8FC;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1A1F36;
  font-weight: 500;
}

.range-sep {
  font-size: 24rpx;
  color: #8792A2;
  margin: 0 12rpx;
  padding-top: 20rpx;
  flex-shrink: 0;
}

.range-apply {
  text-align: center;
  padding: 16rpx;
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 16rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.range-apply:active {
  opacity: 0.9;
}

/* ========== 显示标签 ========== */
.display-tag {
  text-align: center;
  margin-bottom: 16rpx;
}

.display-tag-text {
  font-size: 24rpx;
  color: #667EEA;
  font-weight: 600;
  background-color: rgba(102, 126, 234, 0.08);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.display-tag-sub {
  font-size: 22rpx;
  color: #8792A2;
  margin-left: 4rpx;
}

/* 收支概览 */
.overview-card {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.overview-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.overview-main {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
}

.overview-currency {
  font-size: 32rpx;
  font-weight: 500;
  opacity: 0.9;
}

.overview-balance {
  font-size: 64rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.overview-detail {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 48rpx;
}

.overview-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.overview-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.overview-dot.income {
  background-color: #00D2D3;
}

.overview-dot.expense {
  background-color: #FF6B6B;
}

.overview-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.overview-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* 图表卡片 */
.chart-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

.chart-header {
  margin-bottom: 24rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1F36;
}

.chart-wrap {
  width: 100%;
  height: 400rpx;
}

.chart-wrap.pie {
  width: 400rpx;
  height: 400rpx;
  margin: 0 auto;
}

/* ec-canvas 组件样式 */
.chart-wrap ec-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

/* 图例 */
.legend {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #EDF0F7;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.legend-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-name {
  font-size: 28rpx;
  color: #1A1F36;
}

.legend-percent {
  font-size: 24rpx;
  color: #8792A2;
}

.legend-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1F36;
}

/* 空图表提示 */
.empty-chart {
  text-align: center;
  padding: 80rpx 0;
  color: #8792A2;
  font-size: 28rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}
