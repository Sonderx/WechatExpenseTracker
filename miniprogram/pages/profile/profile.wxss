/**
 * 我的页样式 v2
 * 
 * 设计要点：
 * - 渐变用户卡片
 * - 现代化菜单设计
 */

.page {
  padding: 24rpx 32rpx;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.user-bg {
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.user-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
}

/* 头像按钮（去除默认样式） */
.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  width: auto;
  height: auto;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

/* 用户信息 */
.user-info {
  margin-left: 32rpx;
  flex: 1;
}

.nickname-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.nickname-placeholder {
  color: rgba(255, 255, 255, 0.6);
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 菜单区域 */
.menu-section {
  margin-bottom: 32rpx;
}

.menu-card {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  transition: background-color 0.2s;
}

.menu-item:active {
  background-color: #F7F8FC;
}

.menu-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon {
  font-size: 40rpx;
}

.menu-text {
  flex: 1;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1F36;
  display: block;
  margin-bottom: 4rpx;
}

.menu-desc {
  font-size: 24rpx;
  color: #8792A2;
  display: block;
}

.menu-arrow {
  font-size: 40rpx;
  color: #D1D5E0;
}

.menu-divider {
  height: 1rpx;
  background-color: #EDF0F7;
  margin: 0 32rpx;
}
