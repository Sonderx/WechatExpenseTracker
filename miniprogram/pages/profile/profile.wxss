/**
 * 我的页样式
 */

.page {
  padding: 20rpx 30rpx;
}

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #1AAD19 0%, #158C15 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

/* 头像按钮（去除默认样式） */
.avatar-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  width: auto;
  height: auto;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  background-color: rgba(255, 255, 255, 0.3);
}

/* 昵称输入 */
.nickname-input {
  margin-left: 24rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  flex: 1;
}

/* 菜单卡片 */
.menu-card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f5f5f5;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 24rpx;
  color: #ccc;
}
