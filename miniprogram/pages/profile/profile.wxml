<!--
  我的页 - 用户信息 + 功能菜单 v2
  
  设计要点：
  - 渐变用户卡片
  - 现代化菜单列表
  - 清晰的视觉层次
-->
<view class="page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-bg"></view>
    <view class="user-content">
      <!-- 头像：点击选择头像 -->
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image
          class="avatar"
          src="{{avatarUrl || '/static/default-avatar.png'}}"
          mode="aspectFill"
        />
      </button>
      <!-- 昵称：点击输入昵称 -->
      <view class="user-info">
        <input 
          class="nickname-input" 
          type="nickname" 
          placeholder="点击设置昵称" 
          placeholder-class="nickname-placeholder"
          value="{{nickname}}"
          bindblur="onNicknameInput"
        />
        <text class="user-id">ID: {{userId || '--'}}</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-card">
      <view class="menu-item" bindtap="goCategoryManage">
        <view class="menu-icon-wrap">
          <text class="menu-icon">📂</text>
        </view>
        <view class="menu-text">
          <text class="menu-title">分类管理</text>
          <text class="menu-desc">自定义收支分类</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="goBudgetSetting">
        <view class="menu-icon-wrap">
          <text class="menu-icon">💰</text>
        </view>
        <view class="menu-text">
          <text class="menu-title">预算设置</text>
          <text class="menu-desc">管理月度预算</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-divider"></view>
      <view class="menu-item" bindtap="about">
        <view class="menu-icon-wrap">
          <text class="menu-icon">ℹ️</text>
        </view>
        <view class="menu-text">
          <text class="menu-title">关于</text>
          <text class="menu-desc">版本信息</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>
</view>
