/**
 * 记账页样式
 */

.page {
  padding: 20rpx 30rpx;
}

/* 类型切换 */
.type-switch {
  display: flex;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #666;
  transition: all 0.2s;
}

.type-item.active {
  background-color: #fff;
  font-weight: bold;
}

.type-item.active.expense {
  color: #EE5A5A;
}

.type-item.active.income {
  color: #1AAD19;
}

/* 金额输入 */
.amount-input {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.amount-symbol {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.amount-field {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

/* 区块 */
.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #333;
}

.form-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #666;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
}

/* 提交按钮 */
.submit-btn {
  background-color: #1AAD19;
  color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 40rpx;
}

.submit-btn:active {
  opacity: 0.8;
}
