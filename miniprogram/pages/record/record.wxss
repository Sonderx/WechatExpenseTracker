/**
 * 记账页样式 v2
 * 
 * 设计要点：
 * - 清爽的卡片式布局
 * - 大号金额输入区
 * - 底部固定按钮
 */

.page {
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
}

/* 类型切换 */
.type-switch {
  display: flex;
  background-color: #F7F8FC;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #8792A2;
  position: relative;
  z-index: 1;
  transition: color 0.3s ease;
}

.type-item.active {
  color: #667EEA;
  font-weight: 600;
}

.type-indicator {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: calc(50% - 8rpx);
  height: calc(100% - 16rpx);
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.15);
  transition: transform 0.3s ease;
  z-index: 0;
}

/* 金额输入卡片 */
.amount-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

.amount-label {
  font-size: 26rpx;
  color: #8792A2;
  margin-bottom: 16rpx;
}

.amount-input {
  display: flex;
  align-items: center;
}

.amount-symbol {
  font-size: 56rpx;
  font-weight: 700;
  color: #1A1F36;
  margin-right: 16rpx;
}

.amount-field {
  flex: 1;
  font-size: 64rpx;
  font-weight: 700;
  color: #1A1F36;
  letter-spacing: -2rpx;
}

.amount-placeholder {
  color: #D1D5E0;
}

/* 区块 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  color: #8792A2;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 表单卡片 */
.form-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 8rpx 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

.form-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.form-divider {
  height: 1rpx;
  background-color: #EDF0F7;
}

.form-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #1A1F36;
  font-weight: 500;
}

.form-value-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.form-value {
  font-size: 30rpx;
  color: #8792A2;
}

.form-arrow {
  font-size: 36rpx;
  color: #D1D5E0;
  margin-left: 12rpx;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #1A1F36;
}

.form-placeholder {
  color: #D1D5E0;
}

/* 提交按钮 */
.submit-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: #F7F8FC;
}

.submit-btn {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.4);
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
