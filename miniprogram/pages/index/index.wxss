/**
 * 首页样式 v2
 * 
 * 设计要点：
 * - 渐变汇总卡片，层次分明
 * - 记录列表分组展示
 * - 现代化视觉风格
 */

.page {
  padding-bottom: 160rpx;
  min-height: 100vh;
}

/* 月度汇总卡片 */
.summary-card {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  border-radius: 0 0 48rpx 48rpx;
  padding: 48rpx 40rpx 56rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}

.summary-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.summary-card::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50%;
}

.summary-header {
  position: relative;
  z-index: 1;
  margin-bottom: 32rpx;
}

.summary-month {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.summary-amounts {
  position: relative;
  z-index: 1;
}

.summary-main {
  margin-bottom: 32rpx;
}

.summary-currency {
  font-size: 36rpx;
  font-weight: 500;
  opacity: 0.9;
}

.summary-total {
  font-size: 72rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.summary-detail {
  display: flex;
  gap: 48rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.detail-dot.income {
  background-color: #00D2D3;
}

.detail-dot.expense {
  background-color: #FF6B6B;
}

.detail-label {
  font-size: 24rpx;
  opacity: 0.8;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* 记录区域 */
.record-section {
  padding: 0 32rpx 32rpx;
}

/* 日期分组 */
.day-group {
  margin-bottom: 24rpx;
}

.day-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.day-date {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1F36;
  margin-right: 16rpx;
  white-space: nowrap;
}

.day-line {
  flex: 1;
  height: 1rpx;
  background-color: #EDF0F7;
}

/* 每天记录卡片 */
.record-card {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(102, 126, 234, 0.08);
}

/* 加载提示 */
.loading-tip {
  text-align: center;
  padding: 32rpx;
  color: #8792A2;
  font-size: 24rpx;
}
