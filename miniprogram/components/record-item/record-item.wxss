/**
 * 记录列表项样式 v2
 * 
 * 设计要点：
 * - 圆角图标背景
 * - 清晰的金额展示
 */

.record-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #EDF0F7;
  transition: transform 0.3s ease;
}

.record-item:last-child {
  border-bottom: none;
}

/* 分类图标 */
.record-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08) 0%, rgba(118, 75, 162, 0.08) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.icon-text {
  font-size: 44rpx;
}

/* 记录信息 */
.record-info {
  flex: 1;
  overflow: hidden;
}

.record-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1F36;
  margin-bottom: 8rpx;
}

.record-remark {
  font-size: 24rpx;
  color: #8792A2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 右侧金额和时间 */
.record-right {
  text-align: right;
  flex-shrink: 0;
}

.record-amount {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 22rpx;
  color: #8792A2;
}

/* 滑动状态 */
.sliding {
  position: relative;
  z-index: 1;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
}

.delete-text {
  font-size: 28rpx;
  font-weight: 500;
}
