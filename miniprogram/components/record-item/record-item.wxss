/**
 * 记录列表项样式
 */

.record-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: transform 0.2s ease;
}

/* 分类图标 */
.record-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

/* 记录信息 */
.record-info {
  flex: 1;
  overflow: hidden;
}

.record-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.record-remark {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 右侧金额和时间 */
.record-right {
  text-align: right;
  flex-shrink: 0;
}

.record-amount {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 22rpx;
  color: #999;
}

/* 滑动状态 */
.sliding {
  position: relative;
  z-index: 1;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background-color: #EE5A5A;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  z-index: 0;
}
