<!--
  记录列表项组件 v2
  
  设计要点：
  - 圆角图标
  - 清晰的信息层次
  - 现代化视觉风格
-->
<view 
  class="record-item {{isSliding ? 'sliding' : ''}}"
  style="transform: translateX({{moveX}}rpx);"
  bindtap="onTap"
  catchtouchstart="onTouchStart"
  catchtouchmove="onTouchMove"
  catchtouchend="onTouchEnd"
>
  <!-- 分类图标 -->
  <view class="record-icon">
    <text class="icon-text">{{record.categoryIcon || '📌'}}</text>
  </view>
  
  <!-- 记录信息 -->
  <view class="record-info">
    <view class="record-name">{{record.categoryName || '未分类'}}</view>
    <view class="record-remark" wx:if="{{record.remark}}">{{record.remark}}</view>
  </view>
  
  <!-- 金额和时间 -->
  <view class="record-right">
    <view class="record-amount {{record.amount < 0 ? 'amount-expense' : 'amount-income'}}">
      {{record.amount < 0 ? '-' : '+'}}¥{{record.amount < 0 ? (-record.amount) : record.amount}}
    </view>
    <view class="record-time">{{record.recordTime}}</view>
  </view>
</view>

<!-- 删除按钮 -->
<view class="delete-btn" wx:if="{{isSliding}}" bindtap="onDelete">
  <text class="delete-text">删除</text>
</view>
