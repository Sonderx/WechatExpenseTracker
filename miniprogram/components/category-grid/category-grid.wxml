<!--
  分类图标网格组件 v2
  
  设计要点：
  - 圆角图标背景
  - 选中态高亮
  - 清晰的视觉反馈
-->
<view class="category-grid">
  <view 
    class="category-item {{selectedId === item.id ? 'selected' : ''}}"
    wx:for="{{categories}}"
    wx:key="id"
    data-id="{{item.id}}"
    bindtap="onSelect"
  >
    <view class="category-icon-wrap">
      <text class="category-icon">{{item.icon}}</text>
    </view>
    <text class="category-name">{{item.name}}</text>
  </view>
</view>
