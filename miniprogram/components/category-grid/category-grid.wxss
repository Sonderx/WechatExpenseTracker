/**
 * 分类网格样式
 */

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 0;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.category-item:active {
  background-color: #f0f0f0;
}

.category-item.selected {
  background-color: #e8f5e9;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.category-item.selected .category-icon {
  background-color: #1AAD19;
}

.category-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.category-item.selected .category-name {
  color: #1AAD19;
  font-weight: bold;
}
