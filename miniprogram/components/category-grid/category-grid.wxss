/**
 * 分类网格样式 v2
 * 
 * 设计要点：
 * - 圆角图标背景
 * - 选中态渐变高亮
 */

.category-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx -8rpx;
}

.category-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}

.category-item:active {
  transform: scale(0.95);
}

.category-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background-color: #F7F8FC;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  transition: all 0.2s ease;
}

.category-icon {
  font-size: 44rpx;
}

.category-name {
  font-size: 22rpx;
  color: #8792A2;
  text-align: center;
  transition: all 0.2s ease;
}

/* 选中态 */
.category-item.selected .category-icon-wrap {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.35);
}

.category-item.selected .category-name {
  color: #667EEA;
  font-weight: 600;
}
