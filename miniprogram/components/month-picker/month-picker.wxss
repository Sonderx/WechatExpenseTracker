/**
 * 月份选择器样式
 */

.month-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.arrow {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1AAD19;
  border-radius: 50%;
  background-color: #e8f5e9;
}

.arrow:active {
  background-color: #c8e6c9;
}

.month-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin: 0 40rpx;
}
